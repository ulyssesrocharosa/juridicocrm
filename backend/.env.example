# =============================================
#  JurisCRM - Variáveis de Ambiente
# =============================================

# Servidor
PORT=3001
NODE_ENV=development
# URL pública do backend (obrigatório para o webhook do WhatsApp funcionar)
# Ex: https://seudominio.com ou http://SEU_IP_PUBLICO:3001
BASE_URL=http://localhost:3001

# Segurança JWT
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_troque_isso

# PostgreSQL
# Use a URL do Postgres da sua VPS. Exemplo:
# DATABASE_URL=postgresql://usuario:senha@host:5432/juridico_crm
DATABASE_URL=postgresql://usuario:senha@localhost:5432/juridico_crm
DATABASE_SSL=false

# DataJud API (CNJ)
DATAJUD_API_KEY=sua_chave_datajud
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution
EVOLUTION_INSTANCE_NAME=juridico-crm

# Web Push (notificações browser)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:seu@email.com

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173
